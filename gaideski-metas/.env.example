# Banco de dados (Neon.tech — copie a connection string do painel do Neon)
DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require

# Segredo JWT (gere um string longo e aleatório — ex: rode: openssl rand -base64 32)
JWT_SECRET=seu-segredo-super-longo-aqui

# Ambiente
NODE_ENV=production

# Token opcional para proteger o modo TV
TV_ACCESS_TOKEN=
